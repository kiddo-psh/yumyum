# GMS (Gen AI Management System) API
GMS_API_KEY=여기에_발급받은_GMS_키_입력
GMS_BASE_URL=https://gms.ssafy.io/gmsapi/api.anthropic.com
ANTHROPIC_VERSION=2023-06-01

# 기본 모델: haiku (저비용·빠름) / 심화기능은 claude-opus-4-5-20251101
DEFAULT_MODEL=claude-haiku-4-5-20251001

# 서버 환경: dev(mock) / prod(실제 API 호출)
ENV=dev

SPRING_BASE_URL=http://backend:8080

# 식품안전처 공공데이터 API (data.go.kr 에서 발급)
MFDS_API_KEY=여기에_식품안전처_API_키_입력
